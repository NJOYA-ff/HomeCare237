{
  "extends": [
    "development"
  ],
  "hints": {
    "axe/forms": [
      "default",
      {
        "label": "off"
      }
    ],
    "no-inline-styles": "off",
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "background-position: center",
          "contain",
          "contain: layout",
          "min-height: auto",
          "-webkit-overflow-scrolling",
          "scrollbar-width",
          "scrollbar-color",
          "scrollbar-width: thin",
          "width: fit-content",
          "backdrop-filter",
          "inset"
        ]
      }
    ],
    "meta-viewport": "off",
    "compat-api/html": [
      "default",
      {
        "ignore": [
          "meta[name=color-scheme]"
        ]
      }
    ],
    "apple-touch-icons": "off"
  }
}